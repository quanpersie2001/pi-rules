{
  "name": "@quandev104/pi-rules",
  "version": "0.1.3",
  "description": "Native Pi project rules package with rule injection, commands, and background maintenance.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "rules",
    "extension",
    "skills"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "pi": {
    "extensions": [
      "./dist/extensions/pi-rules.js"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "depcruise": "depcruise extension-src/pi-rules --config dependency-cruiser.config.cjs",
    "check": "npm run typecheck && npm run lint && npm run depcruise && npm test && npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.0.0",
    "dependency-cruiser": "^17.4.3",
    "git-cliff": "^2.13.1",
    "lefthook": "^2.1.9",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
